FREERANGE_PROVIDERS_SMTP_PORT=587
FREERANGE_PROVIDERS_SMTP_USERNAME=mail.themonkeys.life@gmail.com
FREERANGE_PROVIDERS_SMTP_PASSWORD=wtyu jqtl rpcy flpk
FREERANGE_PROVIDERS_SMTP_FROM_EMAIL=mail.themonkeys.life@gmail.com
