# ============================================================
# FreeRangeNotify — Production Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# DO NOT commit .env to git — it contains secrets.

# ── GHCR image source ───────────────────────────────────────
# GitHub username or org that owns the packages
GHCR_OWNER=the-monkeys
# Repository name (lowercase)
GHCR_REPO=freerangenotify

# ── Server ──────────────────────────────────────────────────
FREERANGE_SERVER_PORT=8080

# ── UI ──────────────────────────────────────────────────────
# Port the nginx UI container will be exposed on
UI_PORT=80
# Full URL of the backend API (as seen from the browser)
VITE_API_BASE_URL=https://api.yourdomain.com

# ── Email / SMTP ─────────────────────────────────────────────
FREERANGE_SMTP_HOST=smtp.gmail.com
FREERANGE_SMTP_PORT=587
FREERANGE_SMTP_USER=your@email.com
FREERANGE_SMTP_PASSWORD=your-app-password

# ── SendGrid (if used instead of SMTP) ──────────────────────
FREERANGE_SENDGRID_API_KEY=

# ── JWT / Auth ───────────────────────────────────────────────
FREERANGE_JWT_SECRET=change-me-to-a-long-random-secret

# ── Any other app-specific env vars go here ─────────────────
