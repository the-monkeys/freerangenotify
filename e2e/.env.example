# Test user (must already exist; OTP-verified). Tests do NOT create users.
E2E_USER_EMAIL=replace-me@example.test
E2E_USER_PASSWORD=replace-me

# Optional: pin a specific app id; otherwise the first app on the user is used.
# E2E_APP_ID=442122d5-d5f7-4258-89a9-ed20079becc7

# UI base URL (Vite dev server / docker `ui` service).
E2E_BASE_URL=http://localhost:3000

# API base URL — must include /v1. Local docker exposes the service on 8080.
E2E_API_BASE_URL=http://localhost:8080/v1
